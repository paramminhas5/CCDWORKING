{
  "crons": [
    {
      "path": "/api/cron/scrape-events",
      "schedule": "30 20 * * *"
    },
    {
      "path": "/api/cron/weekly-digest",
      "schedule": "0 1 * * 1"
    },
    {
      "path": "/api/cron/expire-holds",
      "schedule": "0 * * * *"
    }
  ],
  "functions": {
    "pages/api/cron/scrape-events.ts": {
      "maxDuration": 300
    },
    "pages/api/cron/weekly-digest.ts": {
      "maxDuration": 300
    },
    "pages/api/cron/expire-holds.ts": {
      "maxDuration": 60
    },
    "pages/api/[...proxy].ts": {
      "maxDuration": 60
    }
  }
}
