# ═══════════════════════════════════════════════════════════════════════
# CCD Environment Variables
# Copy this to .env.local and fill in your values
# ═══════════════════════════════════════════════════════════════════════

# ── Supabase ──────────────────────────────────────────────────────────
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_KEY=your-service-role-key

# Used by admin panel (client-side, needed for direct admin operations)
NEXT_PUBLIC_SUPABASE_SERVICE_KEY=your-service-role-key

# ── Shopify ───────────────────────────────────────────────────────────
NEXT_PUBLIC_SHOPIFY_STORE_DOMAIN=your-store.myshopify.com
NEXT_PUBLIC_SHOPIFY_STOREFRONT_TOKEN=your-storefront-access-token
NEXT_PUBLIC_SHOPIFY_API_VERSION=2025-10

# ── Admin ─────────────────────────────────────────────────────────────
ADMIN_PASSWORD=84838281

# ── ISR Revalidation ──────────────────────────────────────────────────
REVALIDATE_SECRET=your-random-secret-here

# ── Site ──────────────────────────────────────────────────────────────
NEXT_PUBLIC_SITE_URL=https://catscandance.com
