# ═══════════════════════════════════════════════════════════════════════
# CCD Environment Variables — copy to .env.local
# ═══════════════════════════════════════════════════════════════════════

# ── Supabase (required) ───────────────────────────────────────────────
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key

# Server-only — used by getStaticProps for ISR (never exposed to browser)
SUPABASE_SERVICE_KEY=your-service-role-key

# ── Shopify (optional — shop page shows "offline" without these) ──────
NEXT_PUBLIC_SHOPIFY_STORE_DOMAIN=your-store.myshopify.com
NEXT_PUBLIC_SHOPIFY_STOREFRONT_TOKEN=your-storefront-access-token

# ── ISR Revalidation (optional) ───────────────────────────────────────
REVALIDATE_SECRET=your-random-secret

# ── Site ──────────────────────────────────────────────────────────────
NEXT_PUBLIC_SITE_URL=https://catscandance.com
